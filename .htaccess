# Gzip/Deflate compression for all servers
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml font/ttf font/woff font/woff2
    DeflateCompressionLevel 6
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule LiteSpeed>
    # Enable the cache engine
    CacheEnable public
    RewriteEngine On
    
    # EXCLUSIONS (CRITICAL)
    # Never cache the Admin panel, cart, checkout forms, or payment processors
    RewriteCond %{REQUEST_URI} ^/admin/ [NC,OR]
    RewriteCond %{REQUEST_URI} ^/cart\.php [NC,OR]
    RewriteCond %{REQUEST_URI} ^/checkout\.php [NC,OR]
    RewriteCond %{REQUEST_URI} ^/process_checkout\.php [NC,OR]
    RewriteCond %{REQUEST_URI} ^/checkout_success\.php [NC]
    RewriteRule .* - [E=Cache-Control:no-cache,L]
    
    # INCLUSIONS
    # Cache all other standard GET requests (like index, product details, category) for 10 minutes (600 seconds)
    RewriteCond %{REQUEST_METHOD} ^GET|HEAD$
    RewriteRule .* - [E=Cache-Control:max-age=600]
</IfModule>